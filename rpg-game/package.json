{
  "name": "RPG-game",
  "version": "1.0.0",
  "description": "Школьная RPG-игра с персонажами и оружием",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production",
    "build:babel": "babel src -d dist",
    "lint": "eslint .",
    "test": "jest",
    "coverage": "jest --coverage",
    "start": "webpack serve --mode development",
    "preshow:dist": "npm run build",
    "show:dist": "live-server dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kyoshisu/bhebdps-ojs.git"
  },
  "keywords": [
    "rpg",
    "game",
    "javascript",
    "webpack"
  ],
  "author": "Student",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/js/game.js"
    ]
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "core-js": "^3.49.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@eslint/js": "^9.39.4",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "globals": "^15.15.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "live-server": "^1.2.2",
    "mini-css-extract-plugin": "^2.10.2",
    "webpack": "^5.107.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4"
  }
}
